# LangGraph + Postgres + Redis
DATABASE_URL=postgresql+asyncpg://portfolio_user:secret@localhost:15434/portfolio_issues_agent
REDIS_URL=redis://localhost:6379/3

# Anthropic (drives the drift analyzer + the issue drafter)
ANTHROPIC_API_KEY=
AGENT_MODEL=claude-sonnet-4-6

# Beacon (read portfolio projects to audit)
BEACON_API_URL=https://beacon.danhle.net
BEACON_JWT=

# GitHub (PAT with repo scope for issue creation; public_repo if only public repos)
GITHUB_TOKEN=

# Slack
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_CHANNEL_ID=

# Scheduling
AUDIT_CRON_DAY_OF_WEEK=sun
AUDIT_CRON_HOUR=9

# App
APP_ENV=development
LOG_LEVEL=INFO
PORT=8000
